# The lifecycle manifest (plan/0025) — the single tool-readable journal of the
# agentic-host lifecycle. One [phase "<name>"] stanza per phase, in `order`. This
# file is the source of truth that the three prose copies (CLAUDE.md / STRUCTURE.md
# / UPGRADING.md) now point at instead of re-typing: the phase order, modality,
# driving command, skill, and the evidence a `done` receipt must carry all live here.
#
# `host-lifecycle` reads it (at the project's adopted `.host` revision) for `--next`,
# the `book` lifecycle order, and the `software --check` receipt gate; an agent reads
# it to see the whole lifecycle at a glance (`host-lifecycle manifest <path>`).
#
# Modality is first-class (Decision A, call/0017): the spine rule is "every phase
# emits a receipt," not "every phase runs." A `conditional-on-<X>` phase is
# tool-computed `n-a` where the project lacks X; a `recurring-per-component` phase is
# receipted once per Where-room component. `skippable = false` marks a protected core
# that refuses a `skip`/`n-a` receipt outright (R2).
#
# `recheck =` is the closed re-derivation `software --check` runs to re-verify a
# `done` receipt — never the receipt's own assertion (R1). It MUST be cheap and MUST
# NOT itself re-enter `software --check` (the gate runs it without the nesting guard).

[phase "classify"]
	order    = 1
	modality = unconditional
	command  = host-lifecycle classify
	skill    = classify
	evidence = migration case (a/b/c) + draft rename map
	recheck  = host-lifecycle classify .

[phase "adopt"]
	order    = 2
	modality = unconditional
	command  = host-lifecycle adopt
	skill    = adopt
	evidence = .host stamp (template + revision adopted)
	recheck  = test -f .host

[phase "embed"]
	order    = 3
	modality = conditional-on-Where, recurring-per-component
	command  = host-lifecycle software
	skill    = embed
	evidence = .host-software pin per component
	requires = adopt
	recheck  = test -f .host-software

[phase "remap"]
	order    = 4
	modality = unconditional
	command  = host-lifecycle remap
	skill    = remap
	evidence = .host-remap dictionary applied; naming audit clean
	recheck  = host-lifecycle remap --check .

[phase "verify"]
	order     = 5
	modality  = unconditional
	command   = host-lifecycle software --check
	skill     = verify
	evidence  = gate sweep green (validate, software --check, book --check, hook tell test)
	skippable = false
	recheck   = host-lifecycle validate plan/ call/ && host-lifecycle prose . && host-lifecycle reconcile .

[phase "publish"]
	order    = 6
	modality = unconditional
	command  = host-lifecycle book
	skill    = publish
	evidence = generated mdBook site; doc-site CI lane wired
	recheck  = test -f .github/workflows/mdbook.yml

[phase "upgrade"]
	order    = 7
	modality = unconditional
	command  = host-lifecycle upgrade
	skill    = upgrade
	evidence = .host applied-set (each template revision recorded)
	recheck  = test -f .host

[phase "release"]
	order    = 8
	modality = conditional-on-Where, recurring-per-component
	command  = host-lifecycle release
	skill    = release
	evidence = annotated vX.Y.Z tag + re-derived artifact hash + re-pinned .host-software
	requires = verify
	recheck  = test -f .host-software

# Spine truth data (plan/0036) — not phases. Machine-readable facts the reconcile
# check (the second arm of "grows by reflective practice") diffs a project's own
# docs against, to catch a restatement a spine move staled. These stanzas MUST stay
# after the phase stanzas: the phase parser skips a non-[phase] header and ignores
# the keys here, and the reconcile reader parses these two stanzas directly.

[family]
	# The canonical host-* tool family. A project doc that enumerates the family
	# must name this whole set; a set-diff catches an omission (e.g. a README that
	# drops host-prove). The repo-self stanza ("host") in .host-software is the
	# project's own repo, not a family member, and is not listed here.
	tools = host-lint host-lifecycle host-prove host-grammar

[verification]
	# The verification ladder's rung-drivers, base to deep (plan/0023): hygiene
	# (host-lint), requirements (allium), bounded timing (specula/TLC), and the
	# deeper symbolic/proof/conformance rungs (host-prove). A project doc that
	# describes the verification model must name every driver; an omission (e.g.
	# "three lanes" that drops host-prove) flags.
	drivers = host-lint allium specula host-prove
